# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Production values live in Vercel env vars.

# ─── IMAGE GENERATION (dev-only) ──────────────────────────────────────
# Google Gemini API key — used by scripts/gen-image.mjs and scripts/gen-batch.mjs.
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── JOBBER CRM (lead pipeline) ───────────────────────────────────────
# From Jobber Developer Center → your app → "API Settings".
# The client's Jobber account (the business running the gutter company) must
# be on the Connect plan or higher to have GraphQL API access. The app must be
# installed against the business account (NOT the developer-center account) —
# verify at secure.getjobber.com → Settings → Apps.
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
# IMPORTANT: must match an active version from https://developer.getjobber.com/docs/changelog
# Old strings like "2024-04-22" are NOT recognized and cause the API gateway
# to return 404 on every GraphQL call.
JOBBER_API_VERSION=2025-04-16

# Local OAuth callback. Production uses
# https://washingtongutters4less.com/api/jobber/callback — this must match
# the redirect URI registered in the Jobber Developer Center EXACTLY.
JOBBER_REDIRECT_URI=http://localhost:5739/api/jobber/callback

# Bootstrap refresh token from the one-time OAuth handshake
# (/api/jobber/auth → callback). Jobber rotates it on every refresh; locally
# the dev server writes the rotated value back here, and in production each
# rotation is persisted to Vercel KV (below), so this only needs the initial
# value.
JOBBER_REFRESH_TOKEN=

# ─── TOKEN STORE (production refresh-token persistence) ───────────────
# Vercel env vars are read-only at runtime, and Jobber expires each refresh
# token the moment it's used — so we persist every rotation to a KV store
# (authoritative once written). Add the "Upstash Redis" (or "KV") integration
# from the Vercel Marketplace; it injects these automatically. Either naming
# pair is supported:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (or UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN)

# ─── RESEND EMAIL FALLBACK (paper-trail for every lead) ───────────────
# Backup channel for form submissions. Every /api/jobber/request also
# sends an email here — so even if Jobber blips (cold-start rotation,
# plan change, downtime), Doug still gets the lead in his inbox.
#
# 1. Sign up at https://resend.com (free tier = 100 emails/day, plenty).
# 2. Verify the seamlessgutters4less.com domain (DNS records — takes ~10 min).
# 3. Create an API key, paste below.
#
# If RESEND_API_KEY is blank, the email channel quietly skips and only
# Jobber is used (current pre-launch behavior is preserved).
RESEND_API_KEY=
LEAD_NOTIFY_FROM=Seamless Gutters Website <leads@seamlessgutters4less.com>
LEAD_NOTIFY_TO=info@seamlessgutters4less.com
